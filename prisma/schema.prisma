// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TransType {
  SALE
  RETURN
  EXPENSE
  ADVANCE
  SALARY_PAYMENT
  OWNER_WITHDRAWAL
  AGENT_PURCHASE
  AGENT_PAYMENT
  WARRANTY_REPLACEMENT
  SUPPLIER_WARRANTY_REFUND
}

enum WarrantyStatus {
  ACTIVE
  EXPIRED
  CLAIMED // kept for backward-compat with old records
}

enum SupplierCaseStatus {
  PENDING
  SENT_TO_SUPPLIER
  REPLACED
  REPAIRED
  REFUNDED
  REJECTED
  CLOSED
}

enum PayMethod {
  CASH
  NETWORK
  TABBY
  TAMARA
  CREDIT
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CASHIER
  OWNER
}

enum InventoryCategory {
  POLISH
  COATING
  CONSUMABLE
  EQUIPMENT
  CHEMICAL
  OTHER
}

enum MovementType {
  PURCHASE_IN
  SALE_OUT
  ADJUSTMENT
  RETURN_IN
  WARRANTY_RETURN_IN   // defective item returned by customer
  WARRANTY_OUT         // replacement item given to customer
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  PARTIAL
}

enum ShiftStatus {
  OPEN
  CLOSED
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      Role     @default(CASHIER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  records               Transaction[]         @relation("UserRecords")
  settlements           Settlement[]          @relation("UserSettlements")
  openedShifts          Shift[]               @relation("OpenedShifts")
  closedShifts          Shift[]               @relation("ClosedShifts")
  stockMovements        StockMovement[]
  purchaseOrders        PurchaseOrder[]
  staffProfile          Staff?
  warrantyReplacements  WarrantyReplacement[]
  supplierCases         SupplierWarrantyCase[]
  bnplSessions          BnplSession[]         @relation("UserBnplSessions")
  absenceRecords        AbsenceRecord[]       @relation("AbsenceRecordedBy")
  attendanceRecords     AttendanceRecord[]    @relation("AttendanceRecordedBy")
}

model Staff {
  id                  Int                @id @default(autoincrement())
  name                String
  idNumber            String?            // ID or Iqama Number
  nationality         String?
  baseSalary          Float
  safetyAllowance     Float              @default(0)   // Fixed monthly safety allowance
  overtimeAllowance   Float              @default(0)   // Kept for backward-compat (legacy fixed OT allowance)
  transportAllowance  Float              @default(0)
  otherAllowance      Float              @default(0)
  overtimeMultiplier  Float              @default(1.5) // OT rate multiplier (default 1.5x)
  monthlyHours        Float              @default(208) // Official working hours per month (26d × 8h)
  joiningDate         DateTime?          // Used to prorate salary for first partial month
  isActive            Boolean            @default(true)
  userId              String?            @unique
  user                User?              @relation(fields: [userId], references: [id])
  transactions        Transaction[]
  salarySettlements   SalarySettlement[]
  absenceRecords      AbsenceRecord[]
  attendanceRecords   AttendanceRecord[]
}

model Agent {
  id              Int                  @id @default(autoincrement())
  name            String
  companyName     String?
  openingBalance  Float                @default(0)
  isActive        Boolean              @default(true)
  transactions    Transaction[]
  purchaseOrders  PurchaseOrder[]
  supplierCases   SupplierWarrantyCase[]
}

model Customer {
  id           Int           @id @default(autoincrement())
  name         String
  phone        String?
  email        String?
  notes        String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  transactions Transaction[]
  warranties   Warranty[]
  bnplSessions BnplSession[]
}

model Transaction {
  id                  Int               @id @default(autoincrement())
  type                TransType
  amount              Float
  method              PayMethod         @default(CASH)
  description         String?
  isSettled           Boolean           @default(false)
  staffId             Int?
  staff               Staff?            @relation(fields: [staffId], references: [id])
  agentId             Int?
  agent               Agent?            @relation(fields: [agentId], references: [id])
  settlementId        Int?
  settlement          Settlement?       @relation(fields: [settlementId], references: [id])
  salarySettlementId  Int?
  salarySettlement    SalarySettlement? @relation(fields: [salarySettlementId], references: [id])
  recordedById        String?
  recordedBy          User?             @relation("UserRecords", fields: [recordedById], references: [id])
  linkedTransactionId Int?
  linkedTransaction   Transaction?      @relation("LinkedTransactions", fields: [linkedTransactionId], references: [id])
  linkedBy            Transaction[]     @relation("LinkedTransactions")
  isInternal          Boolean           @default(false)
  invoiceNumber       String?           // For tying split payments and stock movements
  customerId          Int?              // Link to registered Customer
  customer            Customer?         @relation(fields: [customerId], references: [id])
  customerName        String?           // Freetext fallback (kept for backward-compat)
  customerPhone       String?           // Freetext fallback
  dueDate             DateTime?         // For tracking overdue credit invoices
  shiftId             Int?
  shift               Shift?            @relation(fields: [shiftId], references: [id])
  createdAt           DateTime          @default(now())
}

model Settlement {
  id                  Int           @id @default(autoincrement())
  totalCashHanded     Float         // System calculated cash
  actualCashCounted   Float?        // Physically counted cash
  totalNetworkVolume  Float         @default(0)
  totalTabbyVolume    Float         @default(0)
  totalTamaraVolume   Float         @default(0)
  reportDate          DateTime      @default(now())
  transactions        Transaction[]
  performedById       String?
  performedBy         User?         @relation("UserSettlements", fields: [performedById], references: [id])
  shift               Shift?
}

model Shift {
  id              Int       @id @default(autoincrement())
  openedById      String
  openedBy        User      @relation("OpenedShifts", fields: [openedById], references: [id])
  closedById      String?
  closedBy        User?     @relation("ClosedShifts", fields: [closedById], references: [id])
  openedAt        DateTime  @default(now())
  closedAt        DateTime?
  status          ShiftStatus @default(OPEN)
  
  // Sales Summary
  cashSales       Float     @default(0)
  cardSales       Float     @default(0)
  tamaraSales     Float     @default(0)
  tabbySales      Float     @default(0)
  creditSales     Float     @default(0)
  totalSales      Float     @default(0)
  invoiceCount    Int       @default(0)
  
  // Reconciliation
  expectedCash    Float     @default(0)
  actualCash      Float     @default(0)
  difference      Float     @default(0)
  
  denominations   Json?     // { "200": 5, "100": 10, ... }
  
  settlementId    Int?      @unique
  settlement      Settlement? @relation(fields: [settlementId], references: [id])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  transactions    Transaction[]
  bnplSessions    BnplSession[]
}

model SalarySettlement {
  id                    Int           @id @default(autoincrement())
  staffId               Int
  staff                 Staff         @relation(fields: [staffId], references: [id])
  month                 Int
  year                  Int
  // ── Period range ─────────────────────────────────────────
  settlementFrom        DateTime?     // Start date of this settlement period (for locking)
  settledUpToDate       DateTime?     // End date (inclusive) of this settlement period
  // ── Salary base ──────────────────────────────────────────
  baseSalary            Float         // Full monthly basic salary (before pro-ration)
  earnedSalary          Float?        // Pro-rated basic salary earned in this period
  workedDays            Int?          // Calendar days in settlement period
  totalDays             Int?          // Total calendar days in the settlement month
  // ── Allowances ───────────────────────────────────────────
  safetyAllowance       Float         @default(0)  // Safety allowance for this period
  transportAllowance    Float         @default(0)  // Transport allowance snapshot
  otherAllowance        Float         @default(0)  // Other allowance snapshot
  bonus                 Float         @default(0)  // One-time bonus for this settlement
  // ── Overtime (computed from attendance) ──────────────────
  officialHours         Float         @default(0)  // Total official hours worked (≤8h/day, non-Friday)
  overtimeHours         Float         @default(0)  // Regular OT hours (>8h/day, non-Friday)
  fridayHours           Float         @default(0)  // All Friday worked hours (all = OT)
  overtimeAmount        Float         @default(0)  // Regular OT pay
  fridayOvertimeAmount  Float         @default(0)  // Friday OT pay
  overtimeMultiplier    Float         @default(1.5) // Multiplier used at time of settlement
  // ── Deductions ───────────────────────────────────────────
  advancesTally         Float         @default(0)  // Sum of unsettled advances deducted
  absenceHours          Float         @default(0)  // Legacy: manual absence hours
  absenceDeduction      Float         @default(0)  // Legacy: absence deduction amount
  // ── Payment ──────────────────────────────────────────────
  netPaid               Float
  method                PayMethod     @default(CASH)
  cashSource            String?       // CASH_DRAWER | SALARY_FUND (when method=CASH)
  paidAt                DateTime      @default(now())
  transactions          Transaction[]
}

model AbsenceRecord {
  id           Int      @id @default(autoincrement())
  staffId      Int
  staff        Staff    @relation(fields: [staffId], references: [id])
  month        Int
  year         Int
  hours        Float
  reason       String?
  createdAt    DateTime @default(now())
  recordedById String?
  recordedBy   User?    @relation("AbsenceRecordedBy", fields: [recordedById], references: [id])
}

// ── Attendance Records (daily clock-in/out per employee) ────
// Used by payroll engine to calculate overtime & Friday hours
// Foundation for future biometric/HRMS integration
model AttendanceRecord {
  id           Int      @id @default(autoincrement())
  staffId      Int
  staff        Staff    @relation(fields: [staffId], references: [id])
  date         DateTime // The day this record is for (stored at midnight UTC)
  clockIn      DateTime // Actual clock-in datetime
  clockOut     DateTime // Actual clock-out datetime
  workedHours  Float    // Computed hours (clockOut - clockIn)
  isFriday     Boolean  @default(false) // True if the day falls on Friday
  isHoliday    Boolean  @default(false) // Future: mark as public holiday
  note         String?
  recordedById String?
  recordedBy   User?    @relation("AttendanceRecordedBy", fields: [recordedById], references: [id])
  createdAt    DateTime @default(now())

  @@unique([staffId, date]) // One record per employee per day
  @@index([staffId])
  @@index([date])
}

// ── Inventory ──────────────────────────────────────────────

model InventoryItem {
  id               Int               @id @default(autoincrement())
  name             String
  sku              String?           @unique
  category         InventoryCategory @default(OTHER)
  unit             String            @default("pcs") // pcs, L, kg, roll, etc.
  currentStock     Float             @default(0)
  warrantyReturnStock Float          @default(0) // defective items returned by customers
  damagedStock     Float             @default(0) // supplier-rejected / permanently damaged
  reorderLevel     Float             @default(5)
  unitCost         Float             @default(0)
  costIncludesVat  Boolean           @default(false)
  basePrice        Float?            // Pre-VAT selling price (set during Excel import)
  vatRate          Float?            // VAT rate applied (e.g. 0.15 = 15%)
  sellingPrice     Float             @default(0) // Final price after VAT (always the price shown to customer)
  isActive         Boolean           @default(true)
  // ── Warranty config ───────────────────────────────────────
  hasWarranty      Boolean           @default(false)
  warrantyDuration Int?              // e.g. 12
  warrantyUnit     String?           // "months" | "days"
  // warrantyType is always "replacement" — fixed for this system
  // ── Barcode config ────────────────────────────────────────
  barcode          String?           @unique // barcode value (CODE128 / EAN13 / UPC)
  barcodeType      String?           @default("CODE128") // CODE128 | EAN13 | UPC | QR
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  stockMovements          StockMovement[]
  purchaseOrderItems      PurchaseOrderItem[]
  warranties              Warranty[]
  replacementsGiven       WarrantyReplacement[] @relation("ReplacementItem")
  replacementsDefective   WarrantyReplacement[] @relation("DefectiveItem")
  supplierCaseItems       SupplierWarrantyCaseItem[]
}

model StockMovement {
  id              Int            @id @default(autoincrement())
  itemId          Int
  item            InventoryItem  @relation(fields: [itemId], references: [id])
  type            MovementType
  quantity        Float          // positive = in, negative = out
  unitCost        Float?         // cost at time of movement
  sellingPrice    Float?         // selling price at time of movement
  isRestocked     Boolean        @default(true)
  note            String?
  purchaseOrderId Int?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  transactionId   Int?           // optional link to financial Transaction
  invoiceNumber   String?        // to tie movements to specific sales invoices
  recordedById    String?
  recordedBy      User?          @relation(fields: [recordedById], references: [id])
  createdAt       DateTime       @default(now())
}

model PurchaseOrder {
  id           Int            @id @default(autoincrement())
  agentId      Int?           // optional — can purchase without a linked agent
  agent        Agent?         @relation(fields: [agentId], references: [id])
  status       PurchaseStatus @default(RECEIVED)
  totalCost    Float
  method       PayMethod      @default(CASH)
  note         String?
  transactionId Int?          // links to AGENT_PURCHASE transaction in cash flow
  receivedAt   DateTime?
  createdAt    DateTime       @default(now())
  recordedById String?
  recordedBy   User?          @relation(fields: [recordedById], references: [id])

  items     PurchaseOrderItem[]
  movements StockMovement[]
}

model PurchaseOrderItem {
  id              Int           @id @default(autoincrement())
  purchaseOrderId Int
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  itemId          Int
  item            InventoryItem @relation(fields: [itemId], references: [id])
  quantity        Float
  unitCost        Float
  totalCost       Float
}

// ── Warranty ────────────────────────────────────────────────

model Warranty {
  id              Int            @id @default(autoincrement())
  invoiceNumber   String
  itemId          Int
  item            InventoryItem  @relation(fields: [itemId], references: [id])
  customerId      Int?
  customer        Customer?      @relation(fields: [customerId], references: [id])
  customerName    String?        // freetext fallback
  customerPhone   String?
  saleDate        DateTime
  warrantyEndDate DateTime
  status          WarrantyStatus @default(ACTIVE)
  replacementCount Int           @default(0) // total replacements processed
  claimedAt       DateTime?      // kept for backward-compat
  claimNotes      String?        // kept for backward-compat
  replacementTransactionId Int?  // kept for backward-compat
  createdAt       DateTime       @default(now())

  replacements    WarrantyReplacement[]

  @@index([invoiceNumber])
  @@index([itemId])
  @@index([status])
}

// Tracks every individual replacement event
model WarrantyReplacement {
  id                    Int            @id @default(autoincrement())
  warrantyId            Int
  warranty              Warranty       @relation(fields: [warrantyId], references: [id])
  replacementItemId     Int            // item given to customer (usually same as defective)
  replacementItem       InventoryItem  @relation("ReplacementItem", fields: [replacementItemId], references: [id])
  defectiveItemId       Int            // item returned by customer
  defectiveItem         InventoryItem  @relation("DefectiveItem", fields: [defectiveItemId], references: [id])
  quantity              Int            @default(1)
  notes                 String?
  recordedById          String?
  recordedBy            User?          @relation(fields: [recordedById], references: [id])
  transactionId         Int?           // link to WARRANTY_REPLACEMENT transaction
  supplierCaseItemId    Int?           // set when included in a supplier batch
  supplierCaseItem      SupplierWarrantyCaseItem? @relation(fields: [supplierCaseItemId], references: [id])
  createdAt             DateTime       @default(now())

  @@index([warrantyId])
}

// A batch of defective items sent to a supplier
model SupplierWarrantyCase {
  id              Int                      @id @default(autoincrement())
  agentId         Int?                     // the supplier (using Agent model)
  agent           Agent?                   @relation(fields: [agentId], references: [id])
  referenceNumber String?
  status          SupplierCaseStatus       @default(PENDING)
  notes           String?
  sentAt          DateTime?
  resolvedAt      DateTime?
  createdById     String?
  createdBy       User?                    @relation(fields: [createdById], references: [id])
  items           SupplierWarrantyCaseItem[]
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
}

// Items within a supplier warranty batch
model SupplierWarrantyCaseItem {
  id             Int                  @id @default(autoincrement())
  caseId         Int
  case           SupplierWarrantyCase @relation(fields: [caseId], references: [id])
  itemId         Int
  item           InventoryItem        @relation(fields: [itemId], references: [id])
  quantity       Int
  resolutionType String?              // REPLACED | REPAIRED | REFUNDED | REJECTED
  notes          String?
  resolvedAt     DateTime?

  replacements   WarrantyReplacement[]
}

model SystemSettings {
  id                         Int      @id @default(1)
  enableDenominationCounting Boolean  @default(true)
  updatedAt                  DateTime @updatedAt
}

// ── Receipt Template System ─────────────────────────────────

// Stores admin-customizable receipt/invoice template configurations.
// The `config` field holds a serialized ReceiptTemplateConfig JSON object.
// One template may have isDefault=true; all print paths check this first.
model ReceiptTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  isDefault Boolean  @default(false)
  config    Json     // serialized ReceiptTemplateConfig
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Barcode & Label Management ──────────────────────────────

// Saved label template configurations
model LabelTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  config    Json     // Serialized LabelConfig object
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Zebra printer settings (singleton: id=1)
model PrinterSettings {
  id           Int     @id @default(1)
  printerName  String  @default("ZDesigner GK420t")
  dpi          Int     @default(203)
  darkness     Int     @default(15)   // 0-30
  printSpeed   Int     @default(4)    // 2-6 ips
  labelWidth   Float   @default(50)   // mm
  labelHeight  Float   @default(25)   // mm
  updatedAt    DateTime @updatedAt
}

// ── BNPL Payment Sessions (Tabby / Tamara) ─────────────────

enum BnplStatus {
  PENDING_PAYMENT
  PAYMENT_LINK_SENT
  PAID
  FAILED
  EXPIRED
  CANCELLED
}

enum BnplProvider {
  TABBY
  TAMARA
}

model BnplSession {
  id                String      @id @default(cuid())
  provider          BnplProvider
  status            BnplStatus  @default(PENDING_PAYMENT)
  amount            Float
  currency          String      @default("SAR")
  invoiceNumber     String      @unique
  providerSessionId String?     // Provider's own session/order ID
  checkoutUrl       String?     // The payment link shown to customer
  customerPhone     String
  customerName      String?
  customerId        Int?
  customer          Customer?   @relation(fields: [customerId], references: [id])
  cartSnapshot      Json        // Snapshot of items at time of session creation
  webhookPayload    Json?       // Raw webhook body for audit
  expiresAt         DateTime
  paidAt            DateTime?
  failureReason     String?
  recordedById      String?
  recordedBy        User?       @relation("UserBnplSessions", fields: [recordedById], references: [id])
  shiftId           Int?
  shift             Shift?      @relation(fields: [shiftId], references: [id])
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([invoiceNumber])
  @@index([status])
  @@index([provider])
}

