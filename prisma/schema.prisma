// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TransType {
  SALE
  RETURN
  EXPENSE
  ADVANCE
  SALARY_PAYMENT
  OWNER_WITHDRAWAL
  AGENT_PURCHASE
  AGENT_PAYMENT
}

enum PayMethod {
  CASH
  NETWORK
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CASHIER
  OWNER
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      Role     @default(CASHIER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  records   Transaction[] @relation("UserRecords")
  settlements Settlement[] @relation("UserSettlements")
}

model Staff {
  id                Int                @id @default(autoincrement())
  name              String
  baseSalary        Float
  isActive          Boolean            @default(true)
  transactions      Transaction[]
  salarySettlements SalarySettlement[]
}

model Agent {
  id              Int           @id @default(autoincrement())
  name            String
  companyName     String?
  openingBalance  Float         @default(0)
  isActive        Boolean       @default(true)
  transactions    Transaction[]
}

model Transaction {
  id                  Int               @id @default(autoincrement())
  type                TransType
  amount              Float
  method              PayMethod         @default(CASH)
  description         String?
  isSettled           Boolean           @default(false)
  staffId             Int?
  staff               Staff?            @relation(fields: [staffId], references: [id])
  agentId             Int?
  agent               Agent?            @relation(fields: [agentId], references: [id])
  settlementId        Int?
  settlement          Settlement?       @relation(fields: [settlementId], references: [id])
  salarySettlementId  Int?
  salarySettlement    SalarySettlement? @relation(fields: [salarySettlementId], references: [id])
  recordedById        String?
  recordedBy          User?             @relation("UserRecords", fields: [recordedById], references: [id])
  isInternal          Boolean           @default(false)
  createdAt           DateTime          @default(now())
}

model Settlement {
  id                  Int           @id @default(autoincrement())
  totalCashHanded     Float         // System calculated cash
  actualCashCounted   Float?        // Physically counted cash
  totalNetworkVolume  Float         @default(0)
  reportDate          DateTime      @default(now())
  transactions        Transaction[]
  performedById       String?
  performedBy         User?         @relation("UserSettlements", fields: [performedById], references: [id])
}

model SalarySettlement {
  id            Int           @id @default(autoincrement())
  staffId       Int
  staff         Staff         @relation(fields: [staffId], references: [id])
  month         Int
  year          Int
  baseSalary    Float
  advancesTally Float
  netPaid       Float
  method        PayMethod     @default(CASH)
  paidAt        DateTime      @default(now())
  transactions  Transaction[]
}
