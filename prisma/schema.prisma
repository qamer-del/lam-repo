// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TransType {
  SALE
  RETURN
  EXPENSE
  ADVANCE
  SALARY_PAYMENT
  OWNER_WITHDRAWAL
  AGENT_PURCHASE
  AGENT_PAYMENT
  WARRANTY_REPLACEMENT
}

enum WarrantyStatus {
  ACTIVE
  EXPIRED
  CLAIMED
}

enum PayMethod {
  CASH
  NETWORK
  TABBY
  TAMARA
  CREDIT
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CASHIER
  OWNER
}

enum InventoryCategory {
  POLISH
  COATING
  CONSUMABLE
  EQUIPMENT
  CHEMICAL
  OTHER
}

enum MovementType {
  PURCHASE_IN
  SALE_OUT
  ADJUSTMENT
  RETURN_IN
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  PARTIAL
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      Role     @default(CASHIER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  records        Transaction[]   @relation("UserRecords")
  settlements    Settlement[]    @relation("UserSettlements")
  stockMovements StockMovement[]
  purchaseOrders PurchaseOrder[]
  staffProfile   Staff?
}

model Staff {
  id                Int                @id @default(autoincrement())
  name              String
  idNumber          String?            // ID or Iqama Number
  nationality       String?
  baseSalary        Float
  overtimeAllowance Float              @default(0)
  transportAllowance Float             @default(0)
  otherAllowance    Float              @default(0)
  isActive          Boolean            @default(true)
  userId            String?            @unique
  user              User?              @relation(fields: [userId], references: [id])
  transactions      Transaction[]
  salarySettlements SalarySettlement[]
}

model Agent {
  id              Int             @id @default(autoincrement())
  name            String
  companyName     String?
  openingBalance  Float           @default(0)
  isActive        Boolean         @default(true)
  transactions    Transaction[]
  purchaseOrders  PurchaseOrder[]
}

model Customer {
  id           Int           @id @default(autoincrement())
  name         String
  phone        String?
  email        String?
  notes        String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  transactions Transaction[]
  warranties   Warranty[]
}

model Transaction {
  id                  Int               @id @default(autoincrement())
  type                TransType
  amount              Float
  method              PayMethod         @default(CASH)
  description         String?
  isSettled           Boolean           @default(false)
  staffId             Int?
  staff               Staff?            @relation(fields: [staffId], references: [id])
  agentId             Int?
  agent               Agent?            @relation(fields: [agentId], references: [id])
  settlementId        Int?
  settlement          Settlement?       @relation(fields: [settlementId], references: [id])
  salarySettlementId  Int?
  salarySettlement    SalarySettlement? @relation(fields: [salarySettlementId], references: [id])
  recordedById        String?
  recordedBy          User?             @relation("UserRecords", fields: [recordedById], references: [id])
  linkedTransactionId Int?
  linkedTransaction   Transaction?      @relation("LinkedTransactions", fields: [linkedTransactionId], references: [id])
  linkedBy            Transaction[]     @relation("LinkedTransactions")
  isInternal          Boolean           @default(false)
  invoiceNumber       String?           // For tying split payments and stock movements
  customerId          Int?              // Link to registered Customer
  customer            Customer?         @relation(fields: [customerId], references: [id])
  customerName        String?           // Freetext fallback (kept for backward-compat)
  customerPhone       String?           // Freetext fallback
  dueDate             DateTime?         // For tracking overdue credit invoices
  createdAt           DateTime          @default(now())
}

model Settlement {
  id                  Int           @id @default(autoincrement())
  totalCashHanded     Float         // System calculated cash
  actualCashCounted   Float?        // Physically counted cash
  totalNetworkVolume  Float         @default(0)
  totalTabbyVolume    Float         @default(0)
  totalTamaraVolume   Float         @default(0)
  reportDate          DateTime      @default(now())
  transactions        Transaction[]
  performedById       String?
  performedBy         User?         @relation("UserSettlements", fields: [performedById], references: [id])
}

model SalarySettlement {
  id            Int           @id @default(autoincrement())
  staffId       Int
  staff         Staff         @relation(fields: [staffId], references: [id])
  month         Int
  year          Int
  baseSalary    Float
  advancesTally Float
  netPaid       Float
  method        PayMethod     @default(CASH)
  paidAt        DateTime      @default(now())
  transactions  Transaction[]
}

// ── Inventory ──────────────────────────────────────────────

model InventoryItem {
  id               Int               @id @default(autoincrement())
  name             String
  sku              String?           @unique
  category         InventoryCategory @default(OTHER)
  unit             String            @default("pcs") // pcs, L, kg, roll, etc.
  currentStock     Float             @default(0)
  reorderLevel     Float             @default(5)
  unitCost         Float             @default(0)
  costIncludesVat  Boolean           @default(false)
  basePrice        Float?            // Pre-VAT selling price (set during Excel import)
  vatRate          Float?            // VAT rate applied (e.g. 0.15 = 15%)
  sellingPrice     Float             @default(0) // Final price after VAT (always the price shown to customer)
  isActive         Boolean           @default(true)
  // ── Warranty config ───────────────────────────────────────
  hasWarranty      Boolean           @default(false)
  warrantyDuration Int?              // e.g. 12
  warrantyUnit     String?           // "months" | "days"
  // warrantyType is always "replacement" — fixed for this system
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  stockMovements     StockMovement[]
  purchaseOrderItems PurchaseOrderItem[]
  warranties         Warranty[]
}

model StockMovement {
  id              Int            @id @default(autoincrement())
  itemId          Int
  item            InventoryItem  @relation(fields: [itemId], references: [id])
  type            MovementType
  quantity        Float          // positive = in, negative = out
  unitCost        Float?         // cost at time of movement
  sellingPrice    Float?         // selling price at time of movement
  isRestocked     Boolean        @default(true)
  note            String?
  purchaseOrderId Int?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  transactionId   Int?           // optional link to financial Transaction
  invoiceNumber   String?        // to tie movements to specific sales invoices
  recordedById    String?
  recordedBy      User?          @relation(fields: [recordedById], references: [id])
  createdAt       DateTime       @default(now())
}

model PurchaseOrder {
  id           Int            @id @default(autoincrement())
  agentId      Int?           // optional — can purchase without a linked agent
  agent        Agent?         @relation(fields: [agentId], references: [id])
  status       PurchaseStatus @default(RECEIVED)
  totalCost    Float
  method       PayMethod      @default(CASH)
  note         String?
  transactionId Int?          // links to AGENT_PURCHASE transaction in cash flow
  receivedAt   DateTime?
  createdAt    DateTime       @default(now())
  recordedById String?
  recordedBy   User?          @relation(fields: [recordedById], references: [id])

  items     PurchaseOrderItem[]
  movements StockMovement[]
}

model PurchaseOrderItem {
  id              Int           @id @default(autoincrement())
  purchaseOrderId Int
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  itemId          Int
  item            InventoryItem @relation(fields: [itemId], references: [id])
  quantity        Float
  unitCost        Float
  totalCost       Float
}

// ── Warranty ────────────────────────────────────────────────

model Warranty {
  id              Int            @id @default(autoincrement())
  invoiceNumber   String
  itemId          Int
  item            InventoryItem  @relation(fields: [itemId], references: [id])
  customerId      Int?
  customer        Customer?      @relation(fields: [customerId], references: [id])
  customerName    String?        // freetext fallback
  customerPhone   String?
  saleDate        DateTime
  warrantyEndDate DateTime
  status          WarrantyStatus @default(ACTIVE)
  claimedAt       DateTime?
  claimNotes      String?
  replacementTransactionId Int?  // link to WARRANTY_REPLACEMENT transaction
  createdAt       DateTime       @default(now())

  @@index([invoiceNumber])
  @@index([itemId])
  @@index([status])
}
